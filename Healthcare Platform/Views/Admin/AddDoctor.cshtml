@model Healthcare_Platform.Models.Doctor

<h2>Add Doctor</h2>

@if (ViewBag.Error != null)
{
    <p style="color:red">@ViewBag.Error</p>
}

<form method="post">
    <div>
        <label>Assign to User:</label>
        @Html.DropDownList("UserId", (SelectList)ViewBag.Users, "-- Select a User --", new { @class = "form-control" })
    </div>
    <br />
    <div>
        <input type="text" name="Specialization" placeholder="Specialization" class="form-control" />
    </div>
    <br />
    <div>
        <input type="text" name="Availability" placeholder="Availability" class="form-control" />
    </div>
    <br />
    <div>
        <input type="number" name="Rating" placeholder="Rating (0-5)" step="0.1" min="0" max="5" class="form-control" />
    </div>
    <br />
    <button type="submit" class="btn btn-primary">Add Doctor</button>
</form>